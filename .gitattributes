# Normalize line endings for everyone regardless of OS/editor.
* text=auto eol=lf

# Explicit text types
*.yml text
*.yaml text
*.md text
*.json text
*.sh text eol=lf
*.tf text
*.tfvars text
*.hcl text
*.cfg text
*.conf text
*.ini text

# SOPS-encrypted files are ciphertext — never diff/merge them as text.
# Scoped to clusters/** (where k8s Secret payloads live, per docs/secrets.md)
# so this never matches the top-level .sops.yaml rules file itself, which is
# plaintext and must stay diffable — a bare `*.sops.yaml` glob would also
# match that file, since git's gitattributes matching allows `*` to match a
# leading dot.
clusters/**/*.sops.yaml -diff -merge
clusters/**/*.sops.yml -diff -merge
*.sops.tfvars.json -diff -merge
infra/tofu/state.sops.env -diff -merge

# OpenTofu state — natively encrypted ciphertext, never diff/merge as text.
infra/tofu/terraform.tfstate -diff -merge

# Binary/opaque assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.tgz binary
*.age binary
