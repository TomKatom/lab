# OpenTofu — the state file IS committed (natively encrypted); the provider
# lock file IS committed too (reproducible provider pins, Renovate-friendly);
# everything else here is local scratch that must never be.
infra/tofu/.terraform/
infra/tofu/*.tfstate.backup
infra/tofu/crash.log
infra/tofu/override.tf
infra/tofu/override.tf.json
infra/tofu/*_override.tf
infra/tofu/*_override.tf.json
infra/tofu/*.tfplan

# Ansible
ansible/*.retry
ansible/.vault_pass
.ansible/

# SOPS / age — private keys must never live in the repo.
*.age
!*.pub.age
keys.txt
*.agekey

# kubeconfig / talos-style local secrets some tools drop in-tree
kubeconfig
*.kubeconfig
talosconfig

# WireGuard peer keys generated locally per the PR2 runbook (wg genkey/wg
# pubkey) — must never land in the repo, even transiently.
privatekey
publickey

# Helm
**/charts/*.tgz

# Local scratch / overrides that should never be committed
*.local.yaml
*.local.yml
.env
.envrc.local

# Editor / OS cruft
.DS_Store
.DS_Store?
._*
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.iml
