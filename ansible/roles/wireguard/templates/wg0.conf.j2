# Managed by Ansible (roles/wireguard) — do not edit by hand.
[Interface]
Address = {{ network.wireguard_host_address }}
ListenPort = {{ ports.wireguard }}
PrivateKey = {{ wireguard_private_key_slurp.content | b64decode }}
# Table = off: see roles/wireguard/tasks/main.yml's "Render wg0.conf" task.
Table = off
{% for peer in wireguard_peers %}

[Peer]
# {{ peer.name }}
PublicKey = {{ peer.public_key }}
{% if peer.name in (wireguard_peer_psks | default({})) %}
PresharedKey = {{ wireguard_peer_psks[peer.name] }}
{% endif %}
AllowedIPs = {{ peer.address }}
{% if peer.persistent_keepalive is defined %}
PersistentKeepalive = {{ peer.persistent_keepalive }}
{% endif %}
{% endfor %}
