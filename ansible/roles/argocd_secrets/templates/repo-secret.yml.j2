apiVersion: v1
kind: Secret
metadata:
  name: {{ argocd_secrets_repo_secret_name }}
  namespace: {{ argocd_namespace }}
  labels:
    argocd.argoproj.io/secret-type: repository
stringData:
  type: git
  url: {{ argocd_secrets_repo_url }}
  sshPrivateKey: |
{{ argocd_repo_deploy_key | indent(4, first=True) }}
